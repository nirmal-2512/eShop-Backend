<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mini Project Backend</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
  <div class="main bg-gray-700 w-full h-screen flex flex-col text-center items-center justify-center py-10">
    <h1 class="font-bold font-mono text-3xl text-center align-center py-3 text-white"> Mini Project Like Social Media
    </h1>
    <div class="main w-1/3 bg-back h-full overflow-hidden p-10 space-10 text-black">
      <h1 class="font-bold text-3xl text-center align-center py-3 text-white">Login</h1>

      <div class="form bg-gray-900 p-10 rounded-xl">
        <form action="/login" method="post">
          <input type="text" name="email" placeholder="Email"
            class="bg-blue-400 hover:bg-orange-400 outline-none rounded-md p-2 mt-2 w-full">
          <input type="text" name="password" placeholder="password"
            class="bg-blue-400 hover:bg-orange-400 outline-none rounded-md p-2 mt-2 w-full">
          <input type="submit" value="Login" class="bg-orange-600 rounded-md px-20 py-2 mt-2 hover:bg-orange-400">
        </form>
      </div>
    </div>
  </div>
</body>

</html>